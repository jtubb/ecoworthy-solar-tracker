# Bench-test harness configuration.
#
# Copy this file to bench_test_config.yaml, fill in real values, and run:
#   python tools/bench_test.py --all
#
# bench_test_config.yaml is gitignored; this .example is checked in.

nodes:
  solar-tracker-1:
    host: 192.168.1.193
    api_key: "your-base64-encryption-key-here"
  solar-tracker-2:
    host: 192.168.1.194
    api_key: "your-base64-encryption-key-here"

# storm_dwell_test_value: value (minutes) to temporarily set storm_dwell_min
# to during force-park tests.  Lower = faster test.  Restored at end of test.
# Range: 1–60.  Default: 1 (the minimum allowed by the STC firmware).
storm_dwell_test_value: 1

# P5-13 baseline values: reset_to_baseline_() restores these on each node
# before every test, so residual state from prior tests cannot leak into the
# next test's assertions.  Match these to whatever you have configured on the
# bench install (or leave defaults if you're not sure).
baseline_wind_storm_mps: 15
baseline_wind_release_mps: 10
baseline_storm_dwell_min: 10
baseline_track_thresh: 3
